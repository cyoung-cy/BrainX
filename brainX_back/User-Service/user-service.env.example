# User-Service 로컬 실행 설정입니다.
# 이 파일을 복사하여 user-service.env 로 이름을 변경하고 값을 채워넣으세요.

SERVER_PORT=8080
DB_URL=jdbc:postgresql://localhost:5432/brainx_user
DB_USERNAME=postgres
DB_PASSWORD=your_db_password
DB_DRIVER=org.postgresql.Driver
JPA_DDL_AUTO=update
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_TIMEOUT=2s

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_mail@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM=your_mail@gmail.com
EMAIL_VERIFICATION_EXPIRATION_MINUTES=30

FRONTEND_BASE_URL=http://localhost:3000

GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth/google/callback
KAKAO_CLIENT_ID=your_kakao_client_id
KAKAO_CLIENT_SECRET=your_kakao_client_secret
KAKAO_REDIRECT_URI=http://localhost:3000/oauth/kakao/callback
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret
NAVER_REDIRECT_URI=http://localhost:3000/oauth/naver/callback
