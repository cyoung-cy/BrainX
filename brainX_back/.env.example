# 이 파일은 팀원이 참고하는 예시 파일입니다.
# 실제 실행 값은 이 파일을 복사해 brainX_back/.env에 작성하세요.
# .env에는 개인 비밀번호와 OAuth secret이 들어가므로 Git에 올리면 안 됩니다.

# 세 백엔드 서비스가 공통으로 사용하는 설정입니다.
# JWT_SECRET은 User-Service, Workspace-Service, Ingestion-Service가 반드시 같은 값을 써야 합니다.
# 32바이트 이상 길이의 임의 문자열을 사용하세요.
JWT_SECRET=replace_with_same_32_byte_or_longer_secret_for_all_services
FRONTEND_BASE_URL=http://localhost:3000
PUBLIC_BASE_URL=http://localhost:3000
SERVICE_TOKEN=local-service-token

# Docker Compose가 DB 컨테이너를 만들 때 사용하는 계정/DB 이름입니다.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=1234
USER_DB_NAME=brainx_user
WORKSPACE_DB_NAME=brainx_workspace
MYSQL_ROOT_PASSWORD=1234
INGESTION_DB_NAME=brainx_ingestion

# User-Service를 로컬에서 실행할 때 사용하는 설정입니다.
# docker compose의 user-postgres DB와 연결됩니다.
SERVER_PORT=8080
DB_URL=jdbc:postgresql://localhost:5432/brainx_user
DB_USERNAME=postgres
DB_PASSWORD=1234
DB_DRIVER=org.postgresql.Driver
JPA_DDL_AUTO=update

# User-Service의 이메일 인증 발송 설정입니다.
# 로컬에서 실제 메일 발송이 필요 없으면 아래 3개 값을 비워두세요.
# 비워두면 인증 코드는 User-Service 콘솔 로그에 출력됩니다.
# Gmail을 쓰는 경우 MAIL_PASSWORD에는 일반 비밀번호가 아니라 Google 앱 비밀번호를 넣어야 합니다.
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
EMAIL_VERIFICATION_EXPIRATION_MINUTES=30

# User-Service의 소셜 로그인 OAuth 설정입니다.
# 각 플랫폼 개발자 콘솔에서 발급받은 client id/secret을 넣으세요.
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth/google/callback
KAKAO_CLIENT_ID=your_kakao_rest_api_key
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:3000/oauth/kakao/callback
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret
NAVER_REDIRECT_URI=http://localhost:3000/oauth/naver/callback

# Ingestion-Service 담당자가 사용할 Notion 연동 설정입니다.
# Notion 개발자 콘솔의 redirect URI와 NOTION_REDIRECT_URI가 같아야 합니다.
NOTION_CLIENT_ID=your_notion_client_id
NOTION_CLIENT_SECRET=your_notion_client_secret
NOTION_REDIRECT_URI=http://localhost:3000/notion-callback
WORKSPACE_SERVICE_URL=http://localhost:8082

# 주의:
# 세 Spring 서비스가 DB_URL, DB_USERNAME, DB_PASSWORD라는 같은 env 이름을 사용합니다.
# 따라서 여러 백엔드를 IDE에서 동시에 실행할 때는 서비스별 Run Configuration에 DB 값을 따로 넣어야 합니다.
#
# Workspace-Service를 PostgreSQL로 실행할 때 사용할 값:
# DB_URL=jdbc:postgresql://localhost:5433/brainx_workspace
# DB_USERNAME=postgres
# DB_PASSWORD=1234
# DB_DRIVER=org.postgresql.Driver
#
# Ingestion-Service를 MySQL로 실행할 때 사용할 값:
# DB_URL=jdbc:mysql://localhost:3306/brainx_ingestion?useSSL=false&serverTimezone=Asia/Seoul&allowPublicKeyRetrieval=true
# DB_USERNAME=root
# DB_PASSWORD=1234
# DB_DRIVER=com.mysql.cj.jdbc.Driver
