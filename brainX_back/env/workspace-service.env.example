# Workspace-Service local runtime example.
# Copy this file to workspace-service.env and fill in local values.
# workspace-service.env is ignored by Git.

SERVER_PORT=8082
SEED_DEMO_DATA=true

# JWT_SECRET, SERVICE_TOKEN, and PUBLIC_BASE_URL are shared backend settings.
# Put them in brainX_back/.env so every service uses the same value.

# Neo4j is a graph projection/read model. Workspace PostgreSQL remains the
# authoritative note/link ledger. In Docker Compose, NEO4J_URI is overridden to
# bolt://neo4j:7687 for service-to-service access.
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=brainx_neo4j_local_password
NEO4J_BACKFILL_ON_STARTUP=true
