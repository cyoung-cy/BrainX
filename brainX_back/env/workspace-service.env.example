# Workspace-Service local runtime example.
# Copy this file to workspace-service.env and fill in local values.
# workspace-service.env is ignored by Git.

SERVER_PORT=8082
SEED_DEMO_DATA=true
WORKSPACE_DRAFT_TTL_SECONDS=86400
WORKSPACE_DRAFT_FLUSH_INTERVAL_SECONDS=30
WORKSPACE_DRAFT_FLUSH_IDLE_SECONDS=10

# JWT_SECRET, SERVICE_TOKEN, PUBLIC_BASE_URL, and Redis connection settings are shared backend settings.
# Put them in brainX_back/.env so every service uses the same value.
