# Workspace-Service local runtime example.
# Copy this file to workspace-service.env and fill in local values.
# workspace-service.env is ignored by Git.

SERVER_PORT=8082
DB_URL=jdbc:postgresql://postgres:5432/brainx_workspace
DB_USERNAME=postgres
DB_PASSWORD=1234
DB_DRIVER=org.postgresql.Driver
JPA_DDL_AUTO=update
SEED_DEMO_DATA=true

# JWT_SECRET, SERVICE_TOKEN, and PUBLIC_BASE_URL are shared backend settings.
# Put them in brainX_back/.env so every service uses the same value.
