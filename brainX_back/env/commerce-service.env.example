# Commerce-Service 로컬 실행 설정 예시입니다.
# 이 파일을 commerce-service.env로 복사해서 개인 값을 채우세요.
# commerce-service.env는 Git에 올리지 않습니다.

SERVER_PORT=8084
DB_URL=jdbc:postgresql://localhost:5432/brainx_commerce
DB_USERNAME=postgres
DB_PASSWORD=1234
DB_DRIVER=org.postgresql.Driver
JPA_DDL_AUTO=update

PUBLIC_BASE_URL=http://localhost:3000
SERVICE_TOKEN=local-service-token

# Toss Payments 테스트/가맹점 키입니다.
# 로컬에서 결제 승인까지 테스트하려면 Toss 개발자센터 또는 공식 문서의 테스트 키를 넣으세요.
TOSS_CLIENT_KEY=your_toss_client_key
TOSS_SECRET_KEY=your_toss_secret_key
TOSS_CONFIRM_URL=https://api.tosspayments.com/v1/payments/confirm
