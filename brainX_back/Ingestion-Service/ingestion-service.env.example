# Ingestion-Service 로컬 실행 설정입니다.
# 이 파일을 복사하여 ingestion-service.env 로 이름을 변경하고 값을 채워넣으세요.

SERVER_PORT=8083
DB_URL=jdbc:postgresql://localhost:5434/brainx_ingestion
DB_USERNAME=postgres
DB_PASSWORD=your_db_password
DB_DRIVER=org.postgresql.Driver
JPA_DDL_AUTO=update

NOTION_CLIENT_ID=your_notion_client_id
NOTION_CLIENT_SECRET=your_notion_client_secret
NOTION_REDIRECT_URI=http://localhost:3000/notion-callback

WORKSPACE_SERVICE_URL=http://localhost:8082
CDN_BASE_URL=https://cdn.brainx.com
