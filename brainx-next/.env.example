API_SERVER_URL=http://localhost:8088
NEXT_PUBLIC_WORKSPACE_API_BASE_URL=http://localhost:8082
NEXT_PUBLIC_WORKSPACE_DEV_USER_ID=dev-test-user
NEXT_PUBLIC_DEV_AUTH_BYPASS=true

# true: use the existing local mock note data.
# false: load and save notes through Workspace-Service/PostgreSQL.
NEXT_PUBLIC_NOTES_USE_MOCK=false

NEXT_PUBLIC_GRAPH_USE_MOCK=false

# true: use local mock data for the mind-map cluster list.
# false: calculate the cluster list from backend graph data.
NEXT_PUBLIC_GRAPH_CLUSTERS_USE_MOCK=false

INTELLIGENCE_API_BASE_URL=http://localhost:8086
